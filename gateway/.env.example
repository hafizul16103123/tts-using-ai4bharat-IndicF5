# NestJS gateway
PORT=3000

# Redis (see docker-compose.yml — mapped to host port 6380 to avoid clashing with
# any other Redis instance already running on this machine)
REDIS_HOST=127.0.0.1
REDIS_PORT=6380

# Existing Python IndicF5 service (see ../app)
PYTHON_TTS_URL=http://127.0.0.1:8000
PYTHON_TTS_TIMEOUT_MS=60000

# Comma-separated apiKey:userId pairs. Each key maps to an isolated user identity.
API_KEYS=key1:alice,key2:bob

# How many jobs the worker sends to the Python backend at once. Keep at 1 unless the
# Python service is changed to truly parallelize CPU-bound inference (see README).
WORKER_CONCURRENCY=1

# Backpressure: reject new submissions with 429 once this many jobs are queued/active.
MAX_QUEUE_SIZE=20

# Reject text longer than this with 400.
MAX_TEXT_LENGTH=500

# Per-API-key rate limit for POST /tts.
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=10
