HF_TOKEN=your_huggingface_token_here

# How many synthesis requests can run at once, off the event loop, in worker threads.
# Keep in sync with the gateway's WORKER_CONCURRENCY (gateway/.env.example) so the
# gateway never dispatches more concurrent jobs than this service can truly parallelize.
MAX_CONCURRENT_SYNTHESIS=2

# Optional: pin torch's intra-op thread count instead of auto-detecting from the host's
# core count (app/model.py). Only needed when running more than one instance of this
# service on the same host (see docker-compose.scale.yml) — os.cpu_count() reports the
# *host's* full cores inside every container/instance regardless of how many others are
# running, so auto-detection silently oversubscribes the CPU once you scale horizontally.
# TORCH_THREADS=4
